# Server-only secrets for Vercel Serverless Functions — never prefix with VITE_.
# Copy to .env.local for `vercel dev` or configure in the Vercel project dashboard.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — DALL·E 3 text generation (`dalle3` model only). Defaults: hd, natural
OPENAI_DALLE3_QUALITY=
OPENAI_DALLE3_STYLE=

# GPT Image edit (`gpt-image-edit`). Defaults: gpt-image-1.5, high, 1024x1024
OPENAI_GPT_IMAGE_MODEL=
OPENAI_GPT_IMAGE_QUALITY=
OPENAI_GPT_IMAGE_SIZE=

# Experimental Flux placeholder (`flux-control`) — not implemented; optional token for future use
REPLICATE_API_TOKEN=

# --- Shared gallery (Vercel Blob + Postgres/Neon) ---
# Create a Blob store in Vercel → Storage → Blob; linking injects this token.
BLOB_READ_WRITE_TOKEN=
# Neon or other Postgres (Vercel Postgres integration sets POSTGRES_URL).
POSTGRES_URL=
# Alternative name some hosts use:
# DATABASE_URL=

# Site-wide password gate (optional). If unset, /api routes stay open (good for local dev).
GALLERY_SITE_PASSWORD=
# Required when GALLERY_SITE_PASSWORD is set — long random secret for signing session cookies (e.g. openssl rand -hex 32).
GALLERY_SESSION_SECRET=
